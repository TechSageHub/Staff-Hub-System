@model List<Application.Dtos.LeaveRequestDto>
@{
    ViewData["Title"] = "Leave";
    var remainingDays = ViewBag.RemainingDays as int? ?? 0;
    var activeLeave = ViewBag.ActiveLeave as Application.Dtos.ActiveLeaveStatusDto;
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">My leave</h1>
        <p class="sh-page-subtitle">Track your time off and request new leave.</p>
    </div>
    <div class="sh-page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-calendar-plus"></i> Request leave
        </a>
    </div>
</div>

<div class="admin-stat-grid mb-4">
    <div class="admin-stat-card success">
        <div class="admin-stat-icon"><i class="bi bi-calendar2-heart"></i></div>
        <div class="admin-stat-content">
            <div class="admin-stat-value">@remainingDays</div>
            <div class="admin-stat-label">Days of leave remaining this year</div>
        </div>
    </div>
    @if (activeLeave != null)
    {
        <div class="admin-stat-card info">
            <div class="admin-stat-icon"><i class="bi bi-hourglass-split"></i></div>
            <div class="admin-stat-content">
                <div class="admin-stat-value">@activeLeave.RemainingWorkingDays days left</div>
                <div class="admin-stat-label">Current leave · @activeLeave.StartDate.ToString("MMM dd") – @activeLeave.EndDate.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    }
    else
    {
        <div class="admin-stat-card">
            <div class="admin-stat-icon"><i class="bi bi-calendar3"></i></div>
            <div class="admin-stat-content">
                <div class="admin-stat-value">No active leave</div>
                <div class="admin-stat-label">You're currently working. Book time off when you need it.</div>
            </div>
        </div>
    }
</div>

<div class="sh-card">
    <div class="sh-card-header">
        <div>
            <h2 class="sh-card-title">Leave history</h2>
            <div class="sh-card-subtitle">All your leave requests to date</div>
        </div>
    </div>
    @if (!Model.Any())
    {
        <div class="sh-card-body">
            <div class="sh-empty">
                <div class="sh-empty-icon"><i class="bi bi-calendar-x"></i></div>
                <div class="sh-empty-title">No leave requests yet</div>
                <p class="sh-empty-text">Your submitted leave will appear here.</p>
                <a asp-action="Create" class="btn btn-primary mt-2"><i class="bi bi-calendar-plus"></i> Request leave</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="sh-table mb-0">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Dates</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th>Admin comment</th>
                        <th class="text-end">Requested</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:600;">@leave.LeaveType</div>
                                @if (!string.IsNullOrEmpty(leave.Reason))
                                {
                                    <div class="text-muted small text-truncate" style="max-width:240px;">@leave.Reason</div>
                                }
                            </td>
                            <td>@leave.StartDate.ToString("MMM dd") – @leave.EndDate.ToString("MMM dd, yyyy")</td>
                            <td>@leave.DurationInDays</td>
                            <td>
                                @switch (leave.Status)
                                {
                                    case "Approved":
                                        <span class="sh-badge sh-badge-success"><i class="bi bi-check2-circle"></i> Approved</span>
                                        break;
                                    case "Rejected":
                                        <span class="sh-badge sh-badge-danger"><i class="bi bi-x-circle"></i> Rejected</span>
                                        break;
                                    case "Pending":
                                        <span class="sh-badge sh-badge-warning"><i class="bi bi-hourglass-split"></i> Pending</span>
                                        break;
                                    case "Cancelled":
                                        <span class="sh-badge sh-badge-neutral"><i class="bi bi-slash-circle"></i> Cancelled</span>
                                        break;
                                    default:
                                        <span class="sh-badge sh-badge-neutral">@leave.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(leave.AdminComment))
                                {
                                    <span class="text-muted small">—</span>
                                }
                                else
                                {
                                    <span class="small">@leave.AdminComment</span>
                                }
                            </td>
                            <td class="text-end text-muted small">@leave.DateRequested.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
