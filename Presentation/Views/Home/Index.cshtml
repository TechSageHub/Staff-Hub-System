@using Application.Dtos
@{
    ViewData["Title"] = User.Identity?.IsAuthenticated == true ? "Dashboard" : "Modern HR, Built for Growing Teams";

    var myEmployee = ViewBag.MyEmployee as EmployeeDto;
    int leaveBalance = ViewBag.LeaveBalance as int? ?? 0;
    var todayAttendance = ViewBag.TodayAttendance as AttendanceLogDto;
    var announcements = ViewBag.Announcements as List<AnnouncementDto> ?? new List<AnnouncementDto>();
    var landingAnnouncementCount = (int)(ViewBag.LandingAnnouncementCount ?? 0);

    string DisplayName()
    {
        if (myEmployee != null)
        {
            return $"{myEmployee.FirstName} {myEmployee.LastName}".Trim();
        }

        var name = User.Identity?.Name ?? "there";
        var at = name.IndexOf('@');
        return at > 0 ? name.Substring(0, at) : name;
    }
}

@if (!(User.Identity?.IsAuthenticated ?? false))
{
    <section class="sh-lander-hero">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <div class="sh-lander-eyebrow">StaffHub Enterprise HR</div>
                    <h1 class="sh-lander-title">Run your people operations from one polished workspace.</h1>
                    <p class="sh-lander-copy">
                        Centralize onboarding, attendance, leave, announcements, and HR support in a platform designed for teams that want structure without the usual admin drag.
                    </p>
                    <div class="sh-lander-actions">
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                            Start free trial
                        </a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">
                            Sign in
                        </a>
                    </div>
                    <div class="sh-lander-proof">
                        <div class="sh-proof-chip">
                            <strong>20+</strong>
                            <span>leave rules automated</span>
                        </div>
                        <div class="sh-proof-chip">
                            <strong>@landingAnnouncementCount</strong>
                            <span>company updates published</span>
                        </div>
                        <div class="sh-proof-chip">
                            <strong>24/7</strong>
                            <span>HR visibility</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="sh-lander-preview">
                        <div class="sh-preview-card sh-preview-card-main">
                            <div class="sh-preview-header">
                                <span class="sh-preview-dot"></span>
                                <span class="sh-preview-dot"></span>
                                <span class="sh-preview-dot"></span>
                            </div>
                            <div class="sh-preview-body">
                                <div class="sh-preview-panel">
                                    <div class="sh-preview-label">Workforce Pulse</div>
                                    <div class="sh-preview-number">1,248</div>
                                    <div class="sh-preview-trend positive">+14% active employees</div>
                                </div>
                                <div class="sh-preview-grid">
                                    <div class="sh-preview-metric">
                                        <span>Pending leave</span>
                                        <strong>18</strong>
                                    </div>
                                    <div class="sh-preview-metric">
                                        <span>Open tickets</span>
                                        <strong>07</strong>
                                    </div>
                                    <div class="sh-preview-metric">
                                        <span>Clocked in</span>
                                        <strong>92%</strong>
                                    </div>
                                    <div class="sh-preview-metric">
                                        <span>Onboarding</span>
                                        <strong>31</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="sh-preview-card sh-preview-card-float">
                            <div class="small text-uppercase text-muted fw-semibold mb-2">Approval Queue</div>
                            <div class="sh-preview-line"></div>
                            <div class="sh-preview-line short"></div>
                            <div class="sh-preview-badge">Live review</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="sh-lander-section" id="features">
        <div class="container">
            <div class="sh-lander-section-head">
                <div class="sh-lander-eyebrow">Why teams switch</div>
                <h2>Everything HR needs, without scattered spreadsheets and approvals.</h2>
                <p>StaffHub gives operators, managers, and employees one place to work through everyday HR processes with clarity.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-xl-3">
                    <article class="sh-feature-card">
                        <div class="sh-feature-icon"><i class="bi bi-person-workspace"></i></div>
                        <h3>Employee records</h3>
                        <p>Organize profiles, departments, onboarding progress, and contact details in one clean directory.</p>
                    </article>
                </div>
                <div class="col-md-6 col-xl-3">
                    <article class="sh-feature-card">
                        <div class="sh-feature-icon"><i class="bi bi-calendar2-week"></i></div>
                        <h3>Leave control</h3>
                        <p>Handle requests, balances, approvals, and current leave visibility with fewer manual follow-ups.</p>
                    </article>
                </div>
                <div class="col-md-6 col-xl-3">
                    <article class="sh-feature-card">
                        <div class="sh-feature-icon"><i class="bi bi-clock-history"></i></div>
                        <h3>Attendance tracking</h3>
                        <p>See clock-in activity, work history, and team trends without hopping between systems.</p>
                    </article>
                </div>
                <div class="col-md-6 col-xl-3">
                    <article class="sh-feature-card">
                        <div class="sh-feature-icon"><i class="bi bi-headset"></i></div>
                        <h3>HR support desk</h3>
                        <p>Receive employee questions and HR tickets in a workflow that is easy to triage and update.</p>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <section class="sh-lander-section sh-lander-section-alt" id="solutions">
        <div class="container">
            <div class="row g-4 align-items-stretch">
                <div class="col-lg-7">
                    <div class="sh-story-card">
                        <div class="sh-lander-eyebrow">Operations visibility</div>
                        <h2>Designed for fast decisions across HR, leadership, and line managers.</h2>
                        <p>
                            Monitor workforce activity, open approvals, onboarding progress, and internal updates from a dashboard that feels executive-ready, not improvised.
                        </p>
                        <ul class="sh-check-list">
                            <li>Spot onboarding gaps before they become delays</li>
                            <li>Review attendance and leave in one workflow</li>
                            <li>Share company updates without extra tooling</li>
                            <li>Respond to HR tickets with an auditable timeline</li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="sh-side-stack">
                        <div class="sh-side-card">
                            <div class="sh-side-label">Built for</div>
                            <strong>Growing teams</strong>
                            <span>Start simple and scale your HR processes cleanly.</span>
                        </div>
                        <div class="sh-side-card">
                            <div class="sh-side-label">Ideal for</div>
                            <strong>Admin-led operations</strong>
                            <span>Clear approval queues, dashboards, and employee self-service.</span>
                        </div>
                        <div class="sh-side-card">
                            <div class="sh-side-label">Outcome</div>
                            <strong>Less manual overhead</strong>
                            <span>Fewer status chases, better tracking, stronger visibility.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="sh-lander-section" id="about">
        <div class="container">
            <div class="sh-cta-panel">
                <div>
                    <div class="sh-lander-eyebrow">Ready to modernize HR?</div>
                    <h2>Give your team a sharper way to manage people operations.</h2>
                    <p>Start with attendance, leave, onboarding, and support workflows in one branded system.</p>
                </div>
                <div class="sh-cta-actions">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">Create account</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">Access workspace</a>
                </div>
            </div>
        </div>
    </section>
}
else if (User.IsInRole("Admin"))
{
    <partial name="_AdminDashboard" />
}
else
{
    <div class="sh-page-header">
        <div>
            <h1 class="sh-page-title">Hi @DisplayName()</h1>
            <p class="sh-page-subtitle">Here's what matters for your workday right now.</p>
        </div>
        <div class="sh-page-actions">
            <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="EditProfile">
                <i class="bi bi-person-gear"></i> Profile
            </a>
            <a class="btn btn-primary" asp-controller="Leave" asp-action="Create">
                <i class="bi bi-calendar-plus"></i> Request leave
            </a>
        </div>
    </div>

    <div class="admin-stat-grid">
        <div class="admin-stat-card success">
            <div class="admin-stat-icon"><i class="bi bi-calendar2-heart"></i></div>
            <div class="admin-stat-content">
                <div class="admin-stat-value">@leaveBalance</div>
                <div class="admin-stat-label">Days of leave remaining</div>
            </div>
        </div>
        <div class="admin-stat-card info">
            <div class="admin-stat-icon"><i class="bi bi-clock-history"></i></div>
            <div class="admin-stat-content">
                @if (todayAttendance == null)
                {
                    <div class="admin-stat-value">Not clocked in</div>
                    <div class="admin-stat-label">Start your day from Attendance</div>
                }
                else if (todayAttendance.IsActive)
                {
                    <div class="admin-stat-value">@todayAttendance.ClockInTime.ToLocalTime().ToString("HH:mm")</div>
                    <div class="admin-stat-label">Clocked in today</div>
                }
                else
                {
                    <div class="admin-stat-value">@todayAttendance.TotalHours</div>
                    <div class="admin-stat-label">Hours logged today</div>
                }
            </div>
        </div>
        <div class="admin-stat-card @(myEmployee?.IsOnboardingComplete == true ? "success" : "warning")">
            <div class="admin-stat-icon"><i class="bi bi-clipboard-check"></i></div>
            <div class="admin-stat-content">
                @if (myEmployee?.IsOnboardingComplete == true)
                {
                    <div class="admin-stat-value">Complete</div>
                    <div class="admin-stat-label">Your onboarding is fully complete</div>
                }
                else
                {
                    <div class="admin-stat-value">In progress</div>
                    <div class="admin-stat-label"><a asp-controller="Onboarding" asp-action="Index">Finish your onboarding</a></div>
                }
            </div>
        </div>
        <div class="admin-stat-card">
            <div class="admin-stat-icon"><i class="bi bi-building"></i></div>
            <div class="admin-stat-content">
                <div class="admin-stat-value">@(string.IsNullOrWhiteSpace(myEmployee?.DepartmentName) ? "-" : myEmployee!.DepartmentName)</div>
                <div class="admin-stat-label">Your department</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="sh-card">
                <div class="sh-card-header">
                    <div>
                        <h2 class="sh-card-title">Announcements</h2>
                        <div class="sh-card-subtitle">The latest updates from your HR team.</div>
                    </div>
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="Announcement" asp-action="Index">View all</a>
                </div>
                <div class="sh-card-body">
                    @if (!announcements.Any())
                    {
                        <div class="sh-empty">
                            <div class="sh-empty-icon"><i class="bi bi-megaphone"></i></div>
                            <div class="sh-empty-title">No announcements yet</div>
                            <p class="sh-empty-text">New announcements from HR will appear here.</p>
                        </div>
                    }
                    else
                    {
                        foreach (var a in announcements)
                        {
                            <div class="border-bottom pb-3 mb-3" style="border-color: var(--sh-border) !important;">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    @if (a.IsPinned)
                                    {
                                        <span class="sh-badge sh-badge-warning"><i class="bi bi-pin-angle"></i> Pinned</span>
                                    }
                                    <span class="text-muted small">@a.DatePosted.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                </div>
                                <h3 style="font-size:15px; font-weight:600; margin:0 0 4px;">@a.Title</h3>
                                <p class="text-muted small mb-1" style="white-space:pre-wrap;">@a.Content</p>
                                <div class="text-muted" style="font-size:11px;">- @a.AuthorName</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="sh-card">
                <div class="sh-card-header">
                    <h2 class="sh-card-title">Quick actions</h2>
                </div>
                <div class="sh-card-body d-grid gap-2">
                    <a class="btn btn-outline-secondary d-flex justify-content-between align-items-center" asp-controller="Leave" asp-action="Create">
                        <span><i class="bi bi-calendar-plus"></i> Request time off</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a class="btn btn-outline-secondary d-flex justify-content-between align-items-center" asp-controller="HrTicket" asp-action="Create">
                        <span><i class="bi bi-ticket-detailed"></i> Open an HR ticket</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a class="btn btn-outline-secondary d-flex justify-content-between align-items-center" asp-controller="Attendance" asp-action="Index">
                        <span><i class="bi bi-clock-history"></i> View attendance</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a class="btn btn-outline-secondary d-flex justify-content-between align-items-center" asp-controller="Employee" asp-action="MyProfile">
                        <span><i class="bi bi-person-badge"></i> My profile</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

