@using Application.Dtos
@{
    ViewData["Title"] = "Dashboard";
    var myEmployee = ViewBag.MyEmployee as EmployeeDto;
    int? leaveBalance = ViewBag.LeaveBalance as int?;
    var todayAttendance = ViewBag.TodayAttendance as AttendanceLogDto;
    var announcements = ViewBag.Announcements as List<AnnouncementDto> ?? new List<AnnouncementDto>();

    string DisplayName()
    {
        if (myEmployee != null) return $"{myEmployee.FirstName} {myEmployee.LastName}".Trim();
        var name = User.Identity?.Name ?? "there";
        var at = name.IndexOf('@');
        return at > 0 ? name.Substring(0, at) : name;
    }
}

@if (User.Identity!.IsAuthenticated && User.IsInRole("Admin"))
{
    <partial name="_AdminDashboard" />
}
else
{
    <div class="sh-page-header">
        <div>
            <h1 class="sh-page-title">Hi @DisplayName() &#128075;</h1>
            <p class="sh-page-subtitle">Here's what's happening across your workspace today.</p>
        </div>
        <div class="sh-page-actions">
            <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="EditProfile">
                <i class="bi bi-person-gear"></i> Profile
            </a>
            <a class="btn btn-primary" asp-controller="Leave" asp-action="Create">
                <i class="bi bi-calendar-plus"></i> Request leave
            </a>
        </div>
    </div>

    <div class="admin-stat-grid">
        <div class="admin-stat-card success">
            <div class="admin-stat-icon"><i class="bi bi-calendar2-heart"></i></div>
            <div class="admin-stat-content">
                <div class="admin-stat-value">@(leaveBalance?.ToString() ?? "—")</div>
                <div class="admin-stat-label">Days of leave remaining</div>
            </div>
        </div>
        <div class="admin-stat-card info">
            <div class="admin-stat-icon"><i class="bi bi-clock-history"></i></div>
            <div class="admin-stat-content">
                @if (todayAttendance == null)
                {
                    <div class="admin-stat-value">Not clocked in</div>
                    <div class="admin-stat-label">Head to attendance when you start your day</div>
                }
                else if (todayAttendance.IsActive)
                {
                    <div class="admin-stat-value">@todayAttendance.ClockInTime.ToLocalTime().ToString("HH:mm")</div>
                    <div class="admin-stat-label">Clocked in today</div>
                }
                else
                {
                    <div class="admin-stat-value">@todayAttendance.TotalHours</div>
                    <div class="admin-stat-label">Hours logged today</div>
                }
            </div>
        </div>
        <div class="admin-stat-card @(myEmployee?.IsOnboardingComplete == true ? "success" : "warning")">
            <div class="admin-stat-icon"><i class="bi bi-clipboard-check"></i></div>
            <div class="admin-stat-content">
                @if (myEmployee?.IsOnboardingComplete == true)
                {
                    <div class="admin-stat-value">Complete</div>
                    <div class="admin-stat-label">Your profile is fully onboarded</div>
                }
                else
                {
                    <div class="admin-stat-value">In progress</div>
                    <div class="admin-stat-label"><a asp-controller="Onboarding" asp-action="Index">Finish your onboarding</a></div>
                }
            </div>
        </div>
        <div class="admin-stat-card">
            <div class="admin-stat-icon"><i class="bi bi-building"></i></div>
            <div class="admin-stat-content">
                <div class="admin-stat-value">@(string.IsNullOrWhiteSpace(myEmployee?.DepartmentName) ? "—" : myEmployee!.DepartmentName)</div>
                <div class="admin-stat-label">Your department</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="sh-card">
                <div class="sh-card-header">
                    <div>
                        <h2 class="sh-card-title">Announcements</h2>
                        <div class="sh-card-subtitle">The latest from your HR team.</div>
                    </div>
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="Announcement" asp-action="Index">View all</a>
                </div>
                <div class="sh-card-body">
                    @if (!announcements.Any())
                    {
                        <div class="sh-empty">
                            <div class="sh-empty-icon"><i class="bi bi-megaphone"></i></div>
                            <div class="sh-empty-title">No announcements yet</div>
                            <p class="sh-empty-text">New announcements from HR will appear here.</p>
                        </div>
                    }
                    else
                    {
                        foreach (var a in announcements)
                        {
                            <div class="border-bottom pb-3 mb-3" style="border-color: var(--sh-border) !important;">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    @if (a.IsPinned)
                                    {
                                        <span class="sh-badge sh-badge-warning"><i class="bi bi-pin-angle"></i> Pinned</span>
                                    }
                                    <span class="text-muted small">@a.DatePosted.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                </div>
                                <h3 style="font-size:15px; font-weight:600; margin:0 0 4px;">@a.Title</h3>
                                <p class="text-muted small mb-1" style="white-space:pre-wrap;">@a.Content</p>
                                <div class="text-muted" style="font-size:11px;">&mdash; @a.AuthorName</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="sh-card">
                <div class="sh-card-header">
                    <h2 class="sh-card-title">Quick actions</h2>
                </div>
                <div class="sh-card-body d-grid gap-2">
                    <a class="btn btn-outline-secondary d-flex justify-content-between align-items-center" asp-controller="Leave" asp-action="Create">
                        <span><i class="bi bi-calendar-plus"></i> Request time off</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a class="btn btn-outline-secondary d-flex justify-content-between align-items-center" asp-controller="HrTicket" asp-action="Create">
                        <span><i class="bi bi-ticket-detailed"></i> Open an HR ticket</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a class="btn btn-outline-secondary d-flex justify-content-between align-items-center" asp-controller="Attendance" asp-action="Index">
                        <span><i class="bi bi-clock-history"></i> View attendance</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a class="btn btn-outline-secondary d-flex justify-content-between align-items-center" asp-controller="Employee" asp-action="MyProfile">
                        <span><i class="bi bi-person-badge"></i> My profile</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
