@model Presentation.Models.CreateAddressViewModel
@{
    ViewData["Title"] = "Add address";
}

<div class="sh-page-header">
    <div>
        <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-link btn-sm px-0 mb-2" style="text-decoration:none;">
            <i class="bi bi-arrow-left"></i> Back to employee details
        </a>
        <h1 class="sh-page-title">Add employee address</h1>
        <p class="sh-page-subtitle">Provide physical location details for this staff member.</p>
    </div>
</div>

<form asp-action="Add" method="post" class="sh-card" style="max-width: 720px;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="EmployeeId" />
    <div class="sh-card-header">
        <h2 class="sh-card-title">Address details</h2>
    </div>
    <div class="sh-card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert" style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>

        <div class="mb-3">
            <label asp-for="Street" class="form-label"></label>
            <input asp-for="Street" class="form-control" placeholder="e.g. 123 Business Way" />
            <span asp-validation-for="Street" class="invalid-feedback d-block"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="City" class="form-label"></label>
                <input asp-for="City" class="form-control" placeholder="e.g. Ikeja" />
                <span asp-validation-for="City" class="invalid-feedback d-block"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="State" class="form-label"></label>
                <select asp-for="State" class="form-select" asp-items="ViewBag.States">
                    <option value="">-- Select state --</option>
                </select>
                <span asp-validation-for="State" class="invalid-feedback d-block"></span>
            </div>
        </div>

        <div class="mb-0 mt-3">
            <label asp-for="Country" class="form-label"></label>
            <input asp-for="Country" class="form-control" placeholder="e.g. Nigeria" />
            <span asp-validation-for="Country" class="invalid-feedback d-block"></span>
        </div>
    </div>
    <div class="sh-card-footer d-flex gap-2 justify-content-end">
        <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle"></i> Save address
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
