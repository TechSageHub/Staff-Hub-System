@model List<Application.Dtos.AttendanceLogDto>
@{
    ViewData["Title"] = "Attendance overview";
    var employees = ViewBag.Employees as List<Application.Dtos.EmployeeDto> ?? new List<Application.Dtos.EmployeeDto>();
    DateTime? from = ViewBag.From as DateTime?;
    DateTime? to = ViewBag.To as DateTime?;
    Guid? employeeId = ViewBag.EmployeeId as Guid?;
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Attendance overview</h1>
        <p class="sh-page-subtitle">Review attendance by employee or date range.</p>
    </div>
</div>

<div class="sh-card mb-4">
    <div class="sh-card-body">
        <form asp-action="Admin" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">From</label>
                <input type="date" name="from" class="form-control" value="@(from?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To</label>
                <input type="date" name="to" class="form-control" value="@(to?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Employee</label>
                <select name="employeeId" class="form-select">
                    <option value="">All employees</option>
                    @foreach (var emp in employees)
                    {
                        <option value="@emp.Id" selected="@(employeeId.HasValue && employeeId.Value == emp.Id ? "selected" : null)">
                            @emp.FirstName @emp.LastName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<div class="sh-card">
    @if (Model == null || !Model.Any())
    {
        <div class="sh-card-body">
            <div class="sh-empty">
                <div class="sh-empty-icon"><i class="bi bi-clock-history"></i></div>
                <div class="sh-empty-title">No records found</div>
                <p class="sh-empty-text">Try adjusting the filters to broaden your search.</p>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="sh-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Clock in</th>
                        <th>Clock out</th>
                        <th>Total hours</th>
                        <th class="text-end">Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td style="font-weight:600;">@log.EmployeeName</td>
                            <td>@log.ClockInTime.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@(log.ClockOutTime.HasValue ? log.ClockOutTime.Value.ToString("MMM dd, yyyy HH:mm") : "—")</td>
                            <td>@(string.IsNullOrWhiteSpace(log.TotalHours) ? "—" : log.TotalHours)</td>
                            <td class="text-end text-muted small">@(!string.IsNullOrWhiteSpace(log.Notes) ? log.Notes : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
