@model List<Application.Dtos.AttendanceLogDto>
@{
    ViewData["Title"] = "My attendance";
    var todayAttendance = ViewBag.TodayAttendance as Application.Dtos.AttendanceLogDto;
    var daysWorked = Model.Count(a => a.ClockOutTime.HasValue);
    var estimatedHours = Model.Count(a => a.TotalHours != null) * 8;
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Time &amp; attendance</h1>
        <p class="sh-page-subtitle">Track your work hours and attendance history.</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="sh-card h-100">
            <div class="sh-card-header">
                <div>
                    <h2 class="sh-card-title">Today's status</h2>
                    <div class="sh-card-subtitle">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</div>
                </div>
            </div>
            <div class="sh-card-body">
                @if (todayAttendance == null)
                {
                    <div class="sh-alert sh-alert-info mb-3">
                        <i class="bi bi-info-circle"></i>
                        <div>You haven't clocked in yet today.</div>
                    </div>
                    <form asp-action="ClockIn" method="post" class="d-grid">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-play-circle"></i> Clock in
                        </button>
                    </form>
                }
                else if (todayAttendance.IsActive)
                {
                    <div class="sh-alert sh-alert-success mb-3">
                        <i class="bi bi-check-circle"></i>
                        <div>
                            <strong>Clocked in</strong>
                            <div class="small">Started at @todayAttendance.ClockInTime.ToString("HH:mm")</div>
                        </div>
                        <span class="sh-badge sh-badge-success ms-auto">Active</span>
                    </div>
                    <form asp-action="ClockOut" method="post" class="d-grid">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="bi bi-stop-circle"></i> Clock out
                        </button>
                    </form>
                }
                else
                {
                    <div class="sh-alert sh-alert-info mb-3">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>
                            <strong>Day complete</strong>
                            <div class="small">
                                @todayAttendance.ClockInTime.ToString("HH:mm") &mdash; @todayAttendance.ClockOutTime?.ToString("HH:mm")
                                @if (!string.IsNullOrEmpty(todayAttendance.TotalHours))
                                {
                                    <span class="sh-badge sh-badge-info ms-2">@todayAttendance.TotalHours</span>
                                }
                            </div>
                        </div>
                    </div>
                    <button class="btn btn-outline-secondary btn-lg w-100" disabled>
                        <i class="bi bi-check2-all"></i> Day complete
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="admin-stat-grid">
            <div class="admin-stat-card primary">
                <div class="admin-stat-icon"><i class="bi bi-calendar-week"></i></div>
                <div class="admin-stat-content">
                    <div class="admin-stat-value">@daysWorked</div>
                    <div class="admin-stat-label">Days worked this period</div>
                </div>
            </div>
            <div class="admin-stat-card info">
                <div class="admin-stat-icon"><i class="bi bi-hourglass-split"></i></div>
                <div class="admin-stat-content">
                    <div class="admin-stat-value">@estimatedHours</div>
                    <div class="admin-stat-label">Estimated hours</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="sh-card">
    <div class="sh-card-header">
        <div>
            <h2 class="sh-card-title">Attendance history</h2>
            <div class="sh-card-subtitle">Last 30 days</div>
        </div>
    </div>
    @if (!Model.Any())
    {
        <div class="sh-card-body">
            <div class="sh-empty">
                <div class="sh-empty-icon"><i class="bi bi-calendar-x"></i></div>
                <div class="sh-empty-title">No records yet</div>
                <p class="sh-empty-text">Clock in to start tracking your attendance.</p>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="sh-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Clock in</th>
                        <th>Clock out</th>
                        <th>Total hours</th>
                        <th class="text-end">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:600;">@log.ClockInTime.ToString("MMM dd, yyyy")</div>
                                <div class="small text-muted">@log.ClockInTime.ToString("dddd")</div>
                            </td>
                            <td>
                                <span class="sh-badge sh-badge-success">
                                    <i class="bi bi-box-arrow-in-right"></i> @log.ClockInTime.ToString("HH:mm")
                                </span>
                            </td>
                            <td>
                                @if (log.ClockOutTime.HasValue)
                                {
                                    <span class="sh-badge sh-badge-danger">
                                        <i class="bi bi-box-arrow-right"></i> @log.ClockOutTime.Value.ToString("HH:mm")
                                    </span>
                                }
                                else
                                {
                                    <span class="sh-badge sh-badge-warning">In progress</span>
                                }
                            </td>
                            <td>
                                @(string.IsNullOrWhiteSpace(log.TotalHours) ? "—" : log.TotalHours)
                            </td>
                            <td class="text-end">
                                @if (log.IsActive)
                                {
                                    <span class="sh-badge sh-badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="sh-badge sh-badge-neutral">Complete</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
