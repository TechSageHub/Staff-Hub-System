@{
    var isAdmin = User.IsInRole("Admin");
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? string.Empty;
    bool IsActive(string c) => string.Equals(currentController, c, StringComparison.OrdinalIgnoreCase);
    bool IsActiveAny(params string[] cs) => cs.Any(c => string.Equals(currentController, c, StringComparison.OrdinalIgnoreCase));

    var userDisplay = User.Identity?.Name ?? "User";
    var emailLabel = userDisplay;
    var atIndex = userDisplay.IndexOf('@');
    var shortName = atIndex > 0 ? userDisplay.Substring(0, atIndex) : userDisplay;
    var avatarInitial = char.ToUpperInvariant(shortName.FirstOrDefault() == '\0' ? 'U' : shortName.FirstOrDefault());
    var roleLabel = isAdmin ? "Administrator" : "Team member";
    var pageTitle = ViewData["Title"] as string;
    var headerTitle = string.IsNullOrWhiteSpace(pageTitle) ? currentController : pageTitle;
    var isAuth = User.Identity?.IsAuthenticated ?? false;
    var layoutMode = ViewData["LayoutMode"] as string ?? string.Empty;
    var isLanderMode = string.Equals(layoutMode, "Lander", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(string.IsNullOrWhiteSpace(pageTitle) ? "StaffHub" : pageTitle + " - StaffHub")</title>
    <link rel="icon" type="image/png" href="~/favicon.png">
    <script>
        (function () {
            try {
                var t = localStorage.getItem('staffhub.theme');
                if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                document.documentElement.setAttribute('data-bs-theme', t);
            } catch (e) { /* noop */ }
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.41.0/dist/apexcharts.min.js"></script>
</head>
<body class="app-body">
    <div class="admin-shell @(isLanderMode ? "lander-mode" : "")">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        @if (!isLanderMode && isAuth)
        {
            <aside class="admin-sidebar" id="mainSidebar">
            <div class="admin-sidebar-brand">
                <span class="sh-brand-badge"><i class="bi bi-people-fill"></i></span>
                <div class="admin-brand-copy">
                    <span class="admin-brand-title">StaffHub</span>
                    <span class="admin-brand-sub">HR Operations</span>
                </div>
                <button class="admin-sidebar-close d-lg-none" type="button" id="closeSidebar" aria-label="Close sidebar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <nav class="admin-sidebar-scroll" aria-label="Primary navigation">
                <div class="admin-nav-section-title">Main</div>
                <div class="admin-nav-group">
                    <a class="admin-nav-item @(IsActive("Home") ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <span class="admin-nav-icon"><i class="bi bi-speedometer2"></i></span>
                        <span>Dashboard</span>
                    </a>
                    @if (isAdmin)
                    {
                        <a class="admin-nav-item @(IsActive("Analytics") ? "active" : "")" asp-controller="Analytics" asp-action="Index">
                            <span class="admin-nav-icon"><i class="bi bi-graph-up"></i></span>
                            <span>Analytics</span>
                        </a>
                    }
                </div>

                <div class="admin-nav-section-title">Workforce</div>
                <div class="admin-nav-group">
                    @if (isAdmin)
                    {
                        <a class="admin-nav-item @(IsActive("Employee") ? "active" : "")" asp-controller="Employee" asp-action="Index">
                            <span class="admin-nav-icon"><i class="bi bi-people"></i></span>
                            <span>Employees</span>
                        </a>
                        <a class="admin-nav-item @(IsActive("Department") ? "active" : "")" asp-controller="Department" asp-action="Index">
                            <span class="admin-nav-icon"><i class="bi bi-building"></i></span>
                            <span>Departments</span>
                        </a>
                    }
                    else
                    {
                        <a class="admin-nav-item @(IsActive("Employee") ? "active" : "")" asp-controller="Employee" asp-action="MyProfile">
                            <span class="admin-nav-icon"><i class="bi bi-person-badge"></i></span>
                            <span>My profile</span>
                        </a>
                    }
                </div>

                <div class="admin-nav-section-title">HR</div>
                <div class="admin-nav-group">
                    <a class="admin-nav-item @(IsActive("Leave") && currentAction != "AdminDashboard" && currentAction != "Calendar" ? "active" : "")" asp-controller="Leave" asp-action="Index">
                        <span class="admin-nav-icon"><i class="bi bi-calendar2-check"></i></span>
                        <span>@(isAdmin ? "My leave" : "Leave")</span>
                    </a>
                    <a class="admin-nav-item @(IsActive("Leave") && currentAction == "Calendar" ? "active" : "")" asp-controller="Leave" asp-action="Calendar">
                        <span class="admin-nav-icon"><i class="bi bi-calendar3-week"></i></span>
                        <span>Leave calendar</span>
                    </a>
                    @if (isAdmin)
                    {
                        <a class="admin-nav-item @(IsActive("Leave") && currentAction == "AdminDashboard" ? "active" : "")" asp-controller="Leave" asp-action="AdminDashboard">
                            <span class="admin-nav-icon"><i class="bi bi-clipboard2-check"></i></span>
                            <span>Leave queue</span>
                        </a>
                    }
                    <a class="admin-nav-item @(IsActive("HrTicket") && currentAction != "AdminDashboard" ? "active" : "")" asp-controller="HrTicket" asp-action="Index">
                        <span class="admin-nav-icon"><i class="bi bi-ticket-detailed"></i></span>
                        <span>@(isAdmin ? "My tickets" : "HR tickets")</span>
                    </a>
                    @if (isAdmin)
                    {
                        <a class="admin-nav-item @(IsActive("HrTicket") && currentAction == "AdminDashboard" ? "active" : "")" asp-controller="HrTicket" asp-action="AdminDashboard">
                            <span class="admin-nav-icon"><i class="bi bi-headset"></i></span>
                            <span>Ticket queue</span>
                        </a>
                    }
                    <a class="admin-nav-item @(IsActive("Announcement") ? "active" : "")" asp-controller="Announcement" asp-action="Index">
                        <span class="admin-nav-icon"><i class="bi bi-megaphone"></i></span>
                        <span>Announcements</span>
                    </a>
                    <a class="admin-nav-item @(IsActive("Attendance") ? "active" : "")" asp-controller="Attendance" asp-action="Index">
                        <span class="admin-nav-icon"><i class="bi bi-clock-history"></i></span>
                        <span>Attendance</span>
                    </a>
                </div>

                <div class="admin-nav-section-title">Account</div>
                <div class="admin-nav-group">
                    <a class="admin-nav-item @(IsActive("Account") && currentAction == "EditProfile" ? "active" : "")" asp-controller="Account" asp-action="EditProfile">
                        <span class="admin-nav-icon"><i class="bi bi-person-gear"></i></span>
                        <span>Account settings</span>
                    </a>
                    @if (!isAdmin)
                    {
                        <a class="admin-nav-item @(IsActive("Onboarding") ? "active" : "")" asp-controller="Onboarding" asp-action="Index">
                            <span class="admin-nav-icon"><i class="bi bi-clipboard-check"></i></span>
                            <span>Onboarding</span>
                        </a>
                    }
                    <a class="admin-nav-item" asp-controller="Account" asp-action="Logout">
                        <span class="admin-nav-icon"><i class="bi bi-box-arrow-right"></i></span>
                        <span>Sign out</span>
                    </a>
                </div>
            </nav>
        </aside>
        }

        <div class="admin-main">
            <header class="@(isLanderMode ? "lander-nav" : "admin-topbar")">
                <div class="admin-topbar-left">
                    @if (!isLanderMode && isAuth)
                    {
                        <button class="admin-menu-toggle d-lg-none" type="button" id="toggleSidebar" aria-label="Open sidebar">
                            <i class="bi bi-list"></i>
                        </button>
                    }
                    else
                    {
                        <a class="lander-nav-brand" href="/">
                            <span class="sh-brand-badge"><i class="bi bi-people-fill"></i></span>
                            <span>StaffHub</span>
                        </a>
                    }
                    <div class="admin-topbar-title @((!isLanderMode && isAuth) ? "" : "d-none d-md-block")">@headerTitle</div>
                </div>

                <div class="admin-topbar-right">
                    @if (isLanderMode)
                    {
                        <nav class="lander-nav-links d-none d-lg-flex">
                            <a href="#features">Features</a>
                            <a href="#solutions">Solutions</a>
                            <a href="#about">About</a>
                        </nav>
                        <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Login">Sign in</a>
                        <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Get started</a>
                    }
                    else
                    {
                        <button type="button" class="sh-icon-btn" data-sh-theme-toggle aria-pressed="false" aria-label="Toggle theme">
                            <i class="bi bi-moon-stars"></i>
                        </button>

                        <div class="dropdown">
                            <button type="button" class="sh-icon-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Notifications">
                                <i class="bi bi-bell"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end" style="min-width:280px;">
                                <div class="dropdown-header">Notifications</div>
                                <div class="px-2 py-3 text-center text-muted small">
                                    You're all caught up.
                                </div>
                            </div>
                        </div>

                        <div class="dropdown">
                            <button type="button" class="admin-userbox" data-bs-toggle="dropdown" aria-expanded="false" aria-label="User menu">
                                <span class="admin-user-avatar">@avatarInitial</span>
                                <span class="admin-user-meta d-none d-md-flex flex-column text-start">
                                    <span class="admin-user-name">@shortName</span>
                                    <span class="admin-user-role">@roleLabel</span>
                                </span>
                                <i class="bi bi-chevron-down d-none d-md-inline text-muted small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end">
                                <div class="dropdown-header">@emailLabel</div>
                                <a class="dropdown-item" asp-controller="Account" asp-action="EditProfile">
                                    <i class="bi bi-person"></i><span>Profile settings</span>
                                </a>
                                @if (!isAdmin)
                                {
                                    <a class="dropdown-item" asp-controller="Onboarding" asp-action="Index">
                                        <i class="bi bi-clipboard-check"></i><span>Onboarding</span>
                                    </a>
                                }
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i><span>Sign out</span>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </header>

            <main class="admin-content">
                <div class="admin-page-wrap">
                    @await Html.PartialAsync("_FlashMessage")
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await Component.InvokeAsync("Notyf")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

