@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
    Layout = "_AuthLayout";
}

<div class="auth-form">
    <span class="auth-form-eyebrow"><i class="bi bi-envelope-arrow-up"></i> Password reset</span>
    <h1>Forgot your password?</h1>
    <p class="lead">Enter the email associated with your StaffHub account and we'll send you a secure reset link.</p>

    <form asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()

        <div class="sh-form-group">
            <label asp-for="Email" class="form-label">Work email</label>
            <input asp-for="Email" class="form-control" placeholder="you@company.com" autocomplete="email" />
            <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-lg">
            <span>Send reset link</span> <i class="bi bi-send"></i>
        </button>

        <p class="text-center mt-4 mb-0">
            <a asp-action="Login" class="small fw-semibold text-muted">
                <i class="bi bi-arrow-left"></i> Back to sign in
            </a>
        </p>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
