@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Set new password";
    Layout = "_AuthLayout";
}

<div class="auth-form">
    <span class="auth-form-eyebrow"><i class="bi bi-key"></i> New password</span>
    <h1>Create a new password</h1>
    <p class="lead">Pick something strong you haven't used before. We'll sign you in after you save.</p>

    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Token" />

        <div class="sh-form-group">
            <label asp-for="NewPassword" class="form-label">New password</label>
            <div class="sh-input-wrap">
                <input asp-for="NewPassword" type="password" id="resetNewPassword" class="form-control" placeholder="At least 8 characters" autocomplete="new-password" />
                <button type="button" class="sh-input-action" data-sh-toggle-password="#resetNewPassword" tabindex="-1" aria-label="Show password">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <div class="form-text">Must include uppercase, lowercase, a digit, and a symbol.</div>
            <span asp-validation-for="NewPassword" class="invalid-feedback d-block"></span>
        </div>

        <div class="sh-form-group">
            <label asp-for="ConfirmPassword" class="form-label">Confirm new password</label>
            <div class="sh-input-wrap">
                <input asp-for="ConfirmPassword" type="password" id="resetConfirmPassword" class="form-control" placeholder="Repeat new password" autocomplete="new-password" />
                <button type="button" class="sh-input-action" data-sh-toggle-password="#resetConfirmPassword" tabindex="-1" aria-label="Show password">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="invalid-feedback d-block"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-lg mt-2">
            <span>Update password</span> <i class="bi bi-check2-circle"></i>
        </button>

        <p class="text-center mt-4 mb-0">
            <a asp-action="Login" class="small fw-semibold text-muted">
                <i class="bi bi-arrow-left"></i> Back to sign in
            </a>
        </p>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
