@model RegisterViewModel
@{
    ViewData["Title"] = "Create account";
    ViewData["AuthMode"] = "Register";
    Layout = "_AuthLayout";
}

<div class="auth-form auth-form-register">
    <span class="auth-form-eyebrow"><i class="bi bi-rocket-takeoff"></i> Build your workspace</span>
    <h1>Create your StaffHub account</h1>
    <p class="lead">Start with your work email, secure the workspace, and we will guide your team into onboarding right after sign-up.</p>

    <div class="register-signal-row">
        <div class="register-signal-card">
            <strong>Role-aware access</strong>
            <span>Admins and employees see the right actions from day one.</span>
        </div>
        <div class="register-signal-card">
            <strong>Faster setup</strong>
            <span>Move from account creation to first workflow without extra tools.</span>
        </div>
    </div>

    <form asp-action="Register" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert" style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>

        <div class="sh-form-group">
            <label asp-for="Email" class="form-label">Work email</label>
            <input asp-for="Email" class="form-control" placeholder="you@company.com" autocomplete="email" />
            <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
        </div>

        <div class="sh-form-group">
            <label asp-for="Password" class="form-label">Password</label>
            <div class="sh-input-wrap">
                <input asp-for="Password" type="password" id="registerPassword" class="form-control" placeholder="At least 8 characters" autocomplete="new-password" />
                <button type="button" class="sh-input-action" data-sh-toggle-password="#registerPassword" tabindex="-1" aria-label="Show password">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <div class="register-password-note">
                <span><i class="bi bi-check2-circle"></i> Uppercase and lowercase</span>
                <span><i class="bi bi-check2-circle"></i> One digit and one symbol</span>
            </div>
            <span asp-validation-for="Password" class="invalid-feedback d-block"></span>
        </div>

        <div class="sh-form-group">
            <label asp-for="ConfirmPassword" class="form-label">Confirm password</label>
            <div class="sh-input-wrap">
                <input asp-for="ConfirmPassword" type="password" id="confirmPassword" class="form-control" placeholder="Repeat password" autocomplete="new-password" />
                <button type="button" class="sh-input-action" data-sh-toggle-password="#confirmPassword" tabindex="-1" aria-label="Show password">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="invalid-feedback d-block"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-lg mt-2">
            <span>Create workspace account</span> <i class="bi bi-person-plus"></i>
        </button>

        <p class="text-center text-muted small mt-4 mb-0">
            Already have an account? <a asp-action="Login" class="fw-semibold">Sign in</a>
        </p>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
