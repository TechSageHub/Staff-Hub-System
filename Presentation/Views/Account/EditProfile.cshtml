@model Presentation.Models.EditProfileViewModel
@{
    ViewData["Title"] = "Account settings";
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Account settings</h1>
        <p class="sh-page-subtitle">Keep your contact and HR details up to date.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="sh-card">
            <div class="sh-card-body text-center">
                <div class="position-relative d-inline-block mb-3">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" id="profileImagePreview" class="sh-avatar sh-avatar-xl" style="display:inline-flex;" alt="Profile photo" />
                    }
                    else
                    {
                        <div id="profileImagePreviewPlaceholder" class="sh-avatar sh-avatar-xl sh-avatar-primary">
                            <i class="bi bi-person"></i>
                        </div>
                    }
                </div>
                <h2 class="mb-1" style="font-size:16px;">@(string.IsNullOrEmpty(Model.FirstName) ? "Your name" : $"{Model.FirstName} {Model.LastName}")</h2>
                <div class="text-muted small mb-3">@Model.Email</div>
                <label for="Photo" class="btn btn-outline-secondary btn-sm" style="cursor:pointer;">
                    <i class="bi bi-camera"></i> Change photo
                </label>
                <p class="form-text mt-2 mb-0">PNG, JPG up to 5MB.</p>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <form asp-action="EditProfile" method="post" enctype="multipart/form-data" class="sh-card">
            @Html.AntiForgeryToken()
            <div class="sh-card-header">
                <div>
                    <h2 class="sh-card-title">Personal details</h2>
                    <div class="sh-card-subtitle">This information is visible to your HR administrators.</div>
                </div>
            </div>
            <div class="sh-card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert" style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>
                <input type="hidden" asp-for="EmployeeId" />
                <input type="hidden" asp-for="ImageUrl" />
                <input asp-for="Photo" type="file" id="Photo" class="d-none" onchange="previewImage(this)" accept="image/*" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label">First name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="First name" />
                        <span asp-validation-for="FirstName" class="invalid-feedback d-block"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label">Last name</label>
                        <input asp-for="LastName" class="form-control" placeholder="Last name" />
                        <span asp-validation-for="LastName" class="invalid-feedback d-block"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" readonly />
                        <div class="form-text">Login email cannot be changed here.</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label">Phone number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+1 555 123 4567" />
                        <span asp-validation-for="PhoneNumber" class="invalid-feedback d-block"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Female">Female</option>
                            <option value="Male">Male</option>
                            <option value="Other">Other</option>
                            <option value="Prefer not to say">Prefer not to say</option>
                        </select>
                        <span asp-validation-for="Gender" class="invalid-feedback d-block"></span>
                    </div>
                </div>

                <hr class="my-4" style="border-color: var(--sh-border);">

                <h3 class="mb-3" style="font-size:14px; font-weight:600; color:var(--sh-text-muted); text-transform:uppercase; letter-spacing:0.6px;">
                    <i class="bi bi-geo-alt"></i> Address
                </h3>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Street" class="form-label">Street</label>
                        <input asp-for="Street" class="form-control" placeholder="Street address" />
                        <span asp-validation-for="Street" class="invalid-feedback d-block"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="City" class="form-label">City</label>
                        <input asp-for="City" class="form-control" placeholder="City" />
                        <span asp-validation-for="City" class="invalid-feedback d-block"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="State" class="form-label">State</label>
                        <input asp-for="State" class="form-control" placeholder="State" />
                        <span asp-validation-for="State" class="invalid-feedback d-block"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Country" class="form-label">Country</label>
                        <input asp-for="Country" class="form-control" placeholder="Country" />
                        <span asp-validation-for="Country" class="invalid-feedback d-block"></span>
                    </div>
                </div>
            </div>
            <div class="sh-card-footer d-flex gap-2 justify-content-end">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2-circle"></i> Save changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var preview = document.getElementById('profileImagePreview');
                var placeholder = document.getElementById('profileImagePreviewPlaceholder');
                if (preview) {
                    preview.src = e.target.result;
                } else if (placeholder) {
                    var img = document.createElement('img');
                    img.id = 'profileImagePreview';
                    img.src = e.target.result;
                    img.className = 'sh-avatar sh-avatar-xl';
                    img.style.display = 'inline-flex';
                    img.alt = 'Profile photo';
                    placeholder.parentNode.replaceChild(img, placeholder);
                }
            };
            reader.readAsDataURL(input.files[0]);
        }
    </script>
}
