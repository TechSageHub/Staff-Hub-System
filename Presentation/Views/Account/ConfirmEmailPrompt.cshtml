@{
    ViewData["Title"] = "Check your email";
    Layout = "_AuthLayout";
    var email = ViewBag.Email as string;
}

<div class="auth-form text-center">
    <div class="sh-empty-icon mx-auto mb-3" style="background: var(--sh-info-50); color: var(--sh-info); width: 64px; height: 64px; font-size: 28px;">
        <i class="bi bi-envelope-check"></i>
    </div>
    <h1 class="mb-2" style="font-size: 24px;">Confirm your email</h1>
    <p class="lead mb-4">
        We sent a confirmation link to @(string.IsNullOrWhiteSpace(email) ? "your email address" : Html.Raw($"<strong>{email}</strong>")). Click the link to activate your StaffHub account.
    </p>

    <div class="sh-card mb-4 text-start">
        <div class="sh-card-body">
            <div class="d-flex gap-3">
                <div class="sh-stat-icon" style="background: var(--sh-primary-50); color: var(--sh-primary-600); width: 36px; height: 36px; font-size: 16px;">
                    <i class="bi bi-info-circle"></i>
                </div>
                <div class="small text-muted">
                    Didn't get the email? Check your spam folder. The link expires for your safety &mdash; request a new one if needed.
                </div>
            </div>
        </div>
    </div>

    <a asp-action="Login" asp-controller="Account" class="btn btn-primary w-100 btn-lg">
        <span>Back to sign in</span> <i class="bi bi-arrow-right"></i>
    </a>
</div>
