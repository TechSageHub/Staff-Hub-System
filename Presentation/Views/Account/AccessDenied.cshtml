@{
    ViewData["Title"] = "Access denied";
    Layout = "_AuthLayout";
}

<div class="auth-form text-center">
    <div class="sh-empty-icon mx-auto mb-3" style="background: var(--sh-danger-50); color: var(--sh-danger); width: 64px; height: 64px; font-size: 28px;">
        <i class="bi bi-shield-exclamation"></i>
    </div>
    <h1 class="mb-2" style="font-size: 24px;">Access denied</h1>
    <p class="lead mb-4">
        You don't have permission to view this page. If you believe this is a mistake, please contact your HR administrator.
    </p>
    <div class="d-grid gap-2">
        <a asp-action="Index" asp-controller="Home" class="btn btn-primary btn-lg">
            <i class="bi bi-house-door"></i> Back to dashboard
        </a>
        <a asp-action="Logout" asp-controller="Account" class="btn btn-outline-secondary">Sign out</a>
    </div>
</div>
