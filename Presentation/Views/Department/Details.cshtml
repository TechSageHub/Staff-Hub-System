@model Presentation.Models.DepartmentViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="sh-page-header">
    <div>
        <a asp-action="Index" class="btn btn-link btn-sm px-0 mb-2" style="text-decoration:none;"><i class="bi bi-arrow-left"></i> Back to departments</a>
        <h1 class="sh-page-title">@Model.Name</h1>
        <p class="sh-page-subtitle">Organizational unit</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="sh-page-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                <i class="bi bi-pencil"></i> Edit
            </a>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="sh-card">
            <div class="sh-card-header">
                <h2 class="sh-card-title">Description</h2>
            </div>
            <div class="sh-card-body">
                <p class="mb-0" style="white-space:pre-wrap;">@(string.IsNullOrEmpty(Model.Description) ? "No description provided for this department." : Model.Description)</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="admin-stat-card info">
            <div class="admin-stat-icon"><i class="bi bi-people"></i></div>
            <div class="admin-stat-content">
                <div class="admin-stat-value">@Model.EmployeeCount</div>
                <div class="admin-stat-label">Total staff in this department</div>
            </div>
        </div>
    </div>
</div>
