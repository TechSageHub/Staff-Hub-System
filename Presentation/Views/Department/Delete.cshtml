@model Presentation.Models.DepartmentViewModel
@{
    ViewData["Title"] = "Delete department";
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Delete department</h1>
        <p class="sh-page-subtitle">This action cannot be undone.</p>
    </div>
</div>

<div class="sh-card" style="max-width: 560px;">
    <div class="sh-card-body text-center">
        <div class="sh-empty-icon mx-auto mb-3" style="background: var(--sh-danger-50); color: var(--sh-danger); width:64px; height:64px; font-size:28px;">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h2 class="mb-2" style="font-size:18px;">Remove @Model.Name?</h2>
        <p class="text-muted mb-4">All associated data may be affected. Employees in this department will become unassigned.</p>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="sh-info-tile text-start mb-4">
                <div class="sh-info-tile-label">Description</div>
                <div class="small">@Model.Description</div>
            </div>
        }

        <form asp-action="DeleteConfirmed" asp-controller="Department" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash3"></i> Delete permanently
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
