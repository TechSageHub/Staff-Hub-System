@model UpdateDepartmentViewModel
@{
    ViewData["Title"] = "Edit department";
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Edit department</h1>
        <p class="sh-page-subtitle">Update details for @Model.Name.</p>
    </div>
    <div class="sh-page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<form asp-action="Edit" method="post" class="sh-card" style="max-width: 640px;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="sh-card-header">
        <h2 class="sh-card-title">Department details</h2>
    </div>
    <div class="sh-card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert" style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="invalid-feedback d-block"></span>
        </div>
        <div class="mb-0">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="invalid-feedback d-block"></span>
        </div>
    </div>
    <div class="sh-card-footer d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle"></i> Save changes
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
