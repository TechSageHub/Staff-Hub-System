@model DepartmentsViewModel
@{
    ViewData["Title"] = "Departments";
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Departments</h1>
        <p class="sh-page-subtitle">Organizational units across the company.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="sh-page-actions">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> New department
            </a>
        </div>
    }
</div>

@if (!Model.Departments.Any())
{
    <div class="sh-card">
        <div class="sh-card-body">
            <div class="sh-empty">
                <div class="sh-empty-icon"><i class="bi bi-building"></i></div>
                <div class="sh-empty-title">No departments yet</div>
                <p class="sh-empty-text">Create a department to organize your workforce.</p>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary mt-2"><i class="bi bi-plus-lg"></i> Add department</a>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model.Departments)
        {
            <div class="col-md-6 col-xl-4">
                <div class="sh-card h-100">
                    <div class="sh-card-body">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div class="sh-brand-badge" style="width:44px; height:44px; font-size:18px;">
                                <i class="bi bi-diagram-3"></i>
                            </div>
                            <div class="flex-grow-1 min-width-0">
                                <h3 style="font-size:16px; font-weight:600; margin:0 0 2px;">@item.Name</h3>
                                <div class="text-muted small">@item.EmployeeCount employee@(item.EmployeeCount == 1 ? "" : "s")</div>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p class="text-muted small mb-3" style="min-height:42px;">@item.Description</p>
                        }
                        else
                        {
                            <p class="text-muted small mb-3" style="min-height:42px; font-style:italic;">No description.</p>
                        }
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="sh-icon-btn" title="View"><i class="bi bi-eye"></i></a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="sh-icon-btn" title="Edit"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this department?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="sh-icon-btn sh-icon-btn-danger" title="Delete"><i class="bi bi-trash3"></i></button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
