@model Application.Dtos.AnalyticsPageDto
@{
    ViewData["Title"] = "Analytics";
    var f = Model.Filter;
    string DateIso(DateTime d) => d.ToString("yyyy-MM-dd");
    string Money(decimal v) => v.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-US"));
}

<div class="admin-dashboard-page">
    <div class="sh-page-header">
        <div>
            <h1 class="sh-page-title">Analytics</h1>
            <p class="sh-page-subtitle">Deep-dive across leave, attendance, tickets, and workforce.</p>
        </div>
        <div class="sh-page-actions">
            <div class="btn-group">
                <a class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" href="#">
                    <i class="bi bi-filetype-csv"></i> Export CSV
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" asp-action="ExportCsv" asp-route-section="leave" asp-route-from="@DateIso(f.From)" asp-route-to="@DateIso(f.To)" asp-route-dept="@f.DepartmentId">Leave</a></li>
                    <li><a class="dropdown-item" asp-action="ExportCsv" asp-route-section="attendance" asp-route-from="@DateIso(f.From)" asp-route-to="@DateIso(f.To)" asp-route-dept="@f.DepartmentId">Attendance</a></li>
                    <li><a class="dropdown-item" asp-action="ExportCsv" asp-route-section="tickets" asp-route-from="@DateIso(f.From)" asp-route-to="@DateIso(f.To)" asp-route-dept="@f.DepartmentId">Tickets</a></li>
                    <li><a class="dropdown-item" asp-action="ExportCsv" asp-route-section="workforce" asp-route-from="@DateIso(f.From)" asp-route-to="@DateIso(f.To)" asp-route-dept="@f.DepartmentId">Workforce</a></li>
                </ul>
            </div>
            <a class="btn btn-primary" asp-action="ExportPdf" asp-route-from="@DateIso(f.From)" asp-route-to="@DateIso(f.To)" asp-route-dept="@f.DepartmentId">
                <i class="bi bi-filetype-pdf"></i> Export PDF
            </a>
        </div>
    </div>

    <form method="get" class="sh-card mb-3">
        <div class="sh-card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">From</label>
                    <input type="date" class="form-control" name="from" value="@DateIso(f.From)" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">To</label>
                    <input type="date" class="form-control" name="to" value="@DateIso(f.To)" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Department</label>
                    <select class="form-select" name="dept">
                        <option value="">All departments</option>
                        @foreach (var d in Model.Departments)
                        {
                            if (f.DepartmentId == d.Id)
                            {
                                <option value="@d.Id" selected>@d.Name</option>
                            }
                            else
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-funnel"></i> Apply</button>
                </div>
            </div>
        </div>
    </form>

    @* ===== Leave ===== *@
    <h2 class="h5 mt-4 mb-3"><i class="bi bi-calendar2-range text-primary"></i> Leave</h2>
    <div class="admin-stat-grid">
        <div class="admin-stat-card"><div class="admin-stat-icon"><i class="bi bi-clipboard-data"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Leave.TotalRequests</div><div class="admin-stat-label">Requests</div></div></div>
        <div class="admin-stat-card success"><div class="admin-stat-icon"><i class="bi bi-check2-circle"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Leave.ApprovedCount</div><div class="admin-stat-label">Approved</div></div></div>
        <div class="admin-stat-card warning"><div class="admin-stat-icon"><i class="bi bi-hourglass"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Leave.PendingCount</div><div class="admin-stat-label">Pending</div></div></div>
        <div class="admin-stat-card info"><div class="admin-stat-icon"><i class="bi bi-calendar3"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Leave.TotalDaysTaken</div><div class="admin-stat-label">Days taken</div></div></div>
    </div>
    <div class="admin-chart-grid">
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-bar-chart-steps" style="color:var(--sh-primary-600);"></i> Days by leave type</div>
            <div id="leaveByTypeChart" class="admin-chart-host"></div>
        </div>
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-graph-up" style="color:var(--sh-accent);"></i> Monthly days taken</div>
            <div id="leaveMonthlyChart" class="admin-chart-host"></div>
        </div>
    </div>

    @* ===== Attendance ===== *@
    <h2 class="h5 mt-4 mb-3"><i class="bi bi-clock text-primary"></i> Attendance</h2>
    <div class="admin-stat-grid">
        <div class="admin-stat-card success"><div class="admin-stat-icon"><i class="bi bi-check2-square"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Attendance.AttendanceRatePct%</div><div class="admin-stat-label">Attendance rate</div></div></div>
        <div class="admin-stat-card"><div class="admin-stat-icon"><i class="bi bi-door-open"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Attendance.TotalClockIns</div><div class="admin-stat-label">Clock-ins</div></div></div>
        <div class="admin-stat-card info"><div class="admin-stat-icon"><i class="bi bi-people"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Attendance.UniqueActiveEmployees</div><div class="admin-stat-label">Active staff</div></div></div>
        <div class="admin-stat-card warning"><div class="admin-stat-icon"><i class="bi bi-alarm"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Attendance.LateClockIns</div><div class="admin-stat-label">Late (after @Model.Attendance.LateThreshold.ToString(@"hh\:mm"))</div></div></div>
    </div>
    <div class="admin-chart-grid">
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-graph-up-arrow" style="color:var(--sh-primary-600);"></i> Daily clock-ins</div>
            <div id="attDailyChart" class="admin-chart-host"></div>
        </div>
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-diagram-3" style="color:var(--sh-accent);"></i> By department</div>
            <div id="attByDeptChart" class="admin-chart-host"></div>
        </div>
    </div>

    @* ===== Tickets ===== *@
    <h2 class="h5 mt-4 mb-3"><i class="bi bi-ticket-perforated text-primary"></i> HR tickets</h2>
    <div class="admin-stat-grid">
        <div class="admin-stat-card"><div class="admin-stat-icon"><i class="bi bi-inbox"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Tickets.TotalTickets</div><div class="admin-stat-label">Total</div></div></div>
        <div class="admin-stat-card warning"><div class="admin-stat-icon"><i class="bi bi-exclamation-circle"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Tickets.OpenCount</div><div class="admin-stat-label">Open</div></div></div>
        <div class="admin-stat-card info"><div class="admin-stat-icon"><i class="bi bi-arrow-repeat"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Tickets.InProgressCount</div><div class="admin-stat-label">In progress</div></div></div>
        <div class="admin-stat-card success"><div class="admin-stat-icon"><i class="bi bi-check-circle"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Tickets.AvgResolutionHours.ToString("0.0")h</div><div class="admin-stat-label">Avg resolution</div></div></div>
    </div>
    <div class="admin-chart-grid">
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-pie-chart" style="color:var(--sh-primary-600);"></i> By category</div>
            <div id="ticketCategoryChart" class="admin-chart-host"></div>
        </div>
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-flag" style="color:var(--sh-accent);"></i> By priority</div>
            <div id="ticketPriorityChart" class="admin-chart-host"></div>
        </div>
    </div>

    @* ===== Workforce ===== *@
    <h2 class="h5 mt-4 mb-3"><i class="bi bi-people-fill text-primary"></i> Workforce demographics</h2>
    <div class="admin-stat-grid">
        <div class="admin-stat-card"><div class="admin-stat-icon"><i class="bi bi-person-badge"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Model.Workforce.Headcount</div><div class="admin-stat-label">Headcount</div></div></div>
        <div class="admin-stat-card success"><div class="admin-stat-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Money(Model.Workforce.TotalPayroll)</div><div class="admin-stat-label">Total payroll</div></div></div>
        <div class="admin-stat-card info"><div class="admin-stat-icon"><i class="bi bi-cash"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Money(Model.Workforce.AverageSalary)</div><div class="admin-stat-label">Average salary</div></div></div>
        <div class="admin-stat-card warning"><div class="admin-stat-icon"><i class="bi bi-graph-down"></i></div>
            <div class="admin-stat-content"><div class="admin-stat-value">@Money(Model.Workforce.MedianSalary)</div><div class="admin-stat-label">Median salary</div></div></div>
    </div>
    <div class="admin-chart-grid">
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-calendar-heart" style="color:var(--sh-primary-600);"></i> Tenure distribution</div>
            <div id="wfTenureChart" class="admin-chart-host"></div>
        </div>
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-bar-chart" style="color:var(--sh-accent);"></i> Salary bands</div>
            <div id="wfSalaryChart" class="admin-chart-host"></div>
        </div>
    </div>
    <div class="admin-chart-grid">
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-person-plus" style="color:var(--sh-primary-600);"></i> Hires per month</div>
            <div id="wfHiresChart" class="admin-chart-host"></div>
        </div>
        <div class="admin-chart-card">
            <div class="admin-chart-title"><i class="bi bi-diagram-3" style="color:var(--sh-accent);"></i> Headcount by department</div>
            <div id="wfDeptChart" class="admin-chart-host"></div>
        </div>
    </div>

    <p class="text-muted small mt-4">
        <i class="bi bi-info-circle"></i>
        Approval turnaround and turnover rate are not yet available — they require
        processed-at and termination-date fields that haven't been added to the domain model.
    </p>
</div>

<script>
    (function () {
        var leaveByType   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Leave.ByType));
        var leaveMonthly  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Leave.MonthlyDaysTaken));
        var attDaily      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Attendance.DailyTrend));
        var attByDept     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Attendance.ByDepartment));
        var tCategory     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Tickets.ByCategory));
        var tPriority     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Tickets.ByPriority));
        var wfTenure      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Workforce.TenureBuckets));
        var wfSalary      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Workforce.SalaryBuckets));
        var wfHires       = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Workforce.HiresByMonth));
        var wfDept        = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Workforce.HeadcountByDepartment));

        var charts = [];

        function theme() { return (document.documentElement.getAttribute('data-bs-theme') === 'dark') ? 'dark' : 'light'; }
        function tok(n, fb) { var v = getComputedStyle(document.documentElement).getPropertyValue(n).trim(); return v || fb; }
        function colors() {
            var dark = theme() === 'dark';
            return {
                primary: tok('--sh-primary', dark ? '#3b82f6' : '#1e3a8a'),
                primary600: tok('--sh-primary-600', dark ? '#60a5fa' : '#1d4ed8'),
                accent: tok('--sh-accent', dark ? '#38bdf8' : '#0ea5e9'),
                success: tok('--sh-success', '#10b981'),
                warning: tok('--sh-warning', '#f59e0b'),
                danger: tok('--sh-danger', '#ef4444'),
                info: tok('--sh-info', '#0ea5e9'),
                text: dark ? '#e2e8f0' : '#0f172a',
                muted: dark ? '#94a3b8' : '#64748b',
                grid: dark ? '#1f2a44' : '#e5e9f0'
            };
        }
        function palette(c) { return [c.primary600, c.accent, c.success, c.warning, c.danger, c.info, c.primary, '#8b5cf6', '#ec4899', '#14b8a6']; }

        function bar(el, buckets, horizontal) {
            var c = colors(), p = palette(c);
            return {
                chart: { type: 'bar', height: horizontal ? Math.max(280, buckets.length * 36) : 300, toolbar: { show: false }, background: 'transparent', fontFamily: 'Inter, sans-serif' },
                theme: { mode: theme() },
                series: [{ name: 'Value', data: buckets.map(function (b, i) { return { x: b.Label, y: b.Value, fillColor: p[i % p.length] }; }) }],
                plotOptions: { bar: { horizontal: !!horizontal, distributed: true, borderRadius: 6, borderRadiusApplication: 'end', columnWidth: '55%' } },
                colors: p,
                dataLabels: { enabled: true, style: { fontSize: '11px', fontWeight: 600, colors: ['#fff'] } },
                xaxis: { labels: { style: { colors: c.muted, fontSize: '11px', fontWeight: 600 } }, axisBorder: { show: false }, axisTicks: { show: false } },
                yaxis: { labels: { style: { colors: c.text, fontSize: '11px' } } },
                grid: { borderColor: c.grid, strokeDashArray: 4 },
                legend: { show: false },
                tooltip: { theme: theme() }
            };
        }

        function donut(buckets) {
            var c = colors(), p = palette(c);
            return {
                chart: { type: 'donut', height: 300, background: 'transparent', fontFamily: 'Inter, sans-serif' },
                theme: { mode: theme() },
                series: buckets.map(function (b) { return b.Value; }),
                labels: buckets.map(function (b) { return b.Label; }),
                colors: p,
                legend: { position: 'bottom', labels: { colors: c.text } },
                dataLabels: { style: { fontSize: '11px', fontWeight: 600 } },
                tooltip: { theme: theme() }
            };
        }

        function area(buckets, label) {
            var c = colors();
            return {
                chart: { type: 'area', height: 300, toolbar: { show: false }, background: 'transparent', fontFamily: 'Inter, sans-serif' },
                theme: { mode: theme() },
                series: [{ name: label, data: buckets.map(function (b) { return b.Value; }) }],
                xaxis: { categories: buckets.map(function (b) { return b.Label; }), labels: { style: { colors: c.muted, fontSize: '11px' } }, axisBorder: { show: false }, axisTicks: { show: false } },
                yaxis: { labels: { style: { colors: c.muted, fontSize: '11px' } } },
                colors: [c.primary],
                stroke: { curve: 'smooth', width: 3 },
                fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.45, opacityTo: 0, stops: [0, 100] } },
                dataLabels: { enabled: false },
                grid: { borderColor: c.grid, strokeDashArray: 4 },
                tooltip: { theme: theme() }
            };
        }

        function empty(el, msg) {
            el.innerHTML = '<div class="sh-empty" style="padding:32px 0;"><div class="sh-empty-icon"><i class="bi bi-bar-chart"></i></div><div class="sh-empty-title">No data</div><p class="sh-empty-text">' + msg + '</p></div>';
        }

        function mount(id, opts, data, fallback) {
            var el = document.querySelector(id);
            if (!el) return;
            if (!data || data.length === 0 || data.every(function (b) { return b.Value === 0; })) {
                empty(el, fallback || 'Nothing to show for this filter.');
                return;
            }
            var ch = new ApexCharts(el, opts);
            ch.render();
            charts.push({ c: ch, rebuild: function () { return opts; } });
        }

        function render() {
            if (!window.ApexCharts) { setTimeout(render, 100); return; }
            mount('#leaveByTypeChart', bar(null, leaveByType, true), leaveByType);
            mount('#leaveMonthlyChart', area(leaveMonthly, 'Days'), leaveMonthly);
            mount('#attDailyChart', area(attDaily, 'Clock-ins'), attDaily);
            mount('#attByDeptChart', bar(null, attByDept, true), attByDept);
            mount('#ticketCategoryChart', donut(tCategory), tCategory);
            mount('#ticketPriorityChart', donut(tPriority), tPriority);
            mount('#wfTenureChart', bar(null, wfTenure, false), wfTenure);
            mount('#wfSalaryChart', bar(null, wfSalary, false), wfSalary);
            mount('#wfHiresChart', area(wfHires, 'Hires'), wfHires);
            mount('#wfDeptChart', bar(null, wfDept, true), wfDept);
        }

        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', render);
        else render();
    })();
</script>
