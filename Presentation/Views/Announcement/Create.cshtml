@model Application.Dtos.CreateAnnouncementDto
@{
    ViewData["Title"] = "Post announcement";
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Post announcement</h1>
        <p class="sh-page-subtitle">Share an important update with the team.</p>
    </div>
    <div class="sh-page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<form asp-action="Create" method="post" class="sh-card" style="max-width: 720px;">
    @Html.AntiForgeryToken()
    <div class="sh-card-header">
        <h2 class="sh-card-title">Announcement details</h2>
    </div>
    <div class="sh-card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert" style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title</label>
            <input asp-for="Title" class="form-control" placeholder="e.g. Holiday schedule update" required />
            <span asp-validation-for="Title" class="invalid-feedback d-block"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Content" class="form-label">Message</label>
            <textarea asp-for="Content" class="form-control" rows="6" placeholder="Write your announcement here..." required></textarea>
            <span asp-validation-for="Content" class="invalid-feedback d-block"></span>
        </div>

        <div class="form-check form-switch">
            <input asp-for="IsPinned" class="form-check-input" type="checkbox" />
            <label class="form-check-label" asp-for="IsPinned">Pin this announcement to the top</label>
        </div>
    </div>
    <div class="sh-card-footer d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-send"></i> Post announcement
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
