@model Presentation.Models.CreateEmployeeViewModel
@{
    ViewData["Title"] = "Add employee";
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Add employee</h1>
        <p class="sh-page-subtitle">Register a new staff member. They'll receive credentials via email.</p>
    </div>
    <div class="sh-page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to list
        </a>
    </div>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="sh-card" style="max-width: 960px;">
    @Html.AntiForgeryToken()
    <div class="sh-card-header">
        <div>
            <h2 class="sh-card-title">Personal details</h2>
            <div class="sh-card-subtitle">Core identity and contact information.</div>
        </div>
    </div>
    <div class="sh-card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert" style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FirstName" class="form-label">First name</label>
                <input asp-for="FirstName" class="form-control" placeholder="e.g. John" />
                <span asp-validation-for="FirstName" class="invalid-feedback d-block"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastName" class="form-label">Last name</label>
                <input asp-for="LastName" class="form-control" placeholder="e.g. Doe" />
                <span asp-validation-for="LastName" class="invalid-feedback d-block"></span>
            </div>
            <div class="col-md-12">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="john.doe@example.com" />
                <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label">Phone number</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="+1 555 123 4567" />
                <span asp-validation-for="PhoneNumber" class="invalid-feedback d-block"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Gender" class="form-label">Gender</label>
                <select asp-for="Gender" class="form-select">
                    <option value="">-- Select --</option>
                    <option value="Female">Female</option>
                    <option value="Male">Male</option>
                    <option value="Other">Other</option>
                    <option value="Prefer not to say">Prefer not to say</option>
                </select>
                <span asp-validation-for="Gender" class="invalid-feedback d-block"></span>
            </div>
        </div>

        <hr class="my-4" style="border-color: var(--sh-border);">

        <h3 class="sh-section-title"><i class="bi bi-briefcase"></i> Employment</h3>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="HireDate" class="form-label">Hire date</label>
                <input asp-for="HireDate" class="form-control" type="date" />
                <span asp-validation-for="HireDate" class="invalid-feedback d-block"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Salary" class="form-label">Salary</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Salary" class="form-control" placeholder="0.00" />
                </div>
                <span asp-validation-for="Salary" class="invalid-feedback d-block"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="DepartmentId" class="form-label">Department</label>
                <select asp-for="DepartmentId" class="form-select" asp-items="Model.Departments">
                    <option value="">-- Select department --</option>
                </select>
                <span asp-validation-for="DepartmentId" class="invalid-feedback d-block"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Photo" class="form-label">Profile photo</label>
                <input asp-for="Photo" type="file" class="form-control" accept="image/*" />
                <div class="form-text">Optional. PNG or JPG, max 2MB.</div>
                <span asp-validation-for="Photo" class="invalid-feedback d-block"></span>
            </div>
        </div>

        <hr class="my-4" style="border-color: var(--sh-border);">

        <h3 class="sh-section-title"><i class="bi bi-geo-alt"></i> Address <span class="text-muted small ms-2" style="text-transform:none; letter-spacing:0;">(optional)</span></h3>
        <div class="row g-3">
            <div class="col-12">
                <label asp-for="Street" class="form-label">Street</label>
                <input asp-for="Street" class="form-control" placeholder="Street address" />
            </div>
            <div class="col-md-4">
                <label asp-for="City" class="form-label">City</label>
                <input asp-for="City" class="form-control" placeholder="City" />
            </div>
            <div class="col-md-4">
                <label asp-for="State" class="form-label">State</label>
                <select asp-for="State" class="form-select" asp-items="Model.States">
                    <option value="">-- Select state --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="Country" class="form-label">Country</label>
                <input asp-for="Country" class="form-control" />
            </div>
        </div>
    </div>
    <div class="sh-card-footer d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle"></i> Create employee
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
