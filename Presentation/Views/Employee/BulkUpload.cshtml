@model Presentation.Models.BulkUploadViewModel
@{
    ViewData["Title"] = "Bulk upload";
}

<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Bulk upload</h1>
        <p class="sh-page-subtitle">Import multiple employees at once from a CSV file.</p>
    </div>
    <div class="sh-page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to list
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <form asp-action="BulkUpload" method="post" enctype="multipart/form-data" class="sh-card">
            @Html.AntiForgeryToken()
            <div class="sh-card-header">
                <div>
                    <h2 class="sh-card-title">Upload CSV</h2>
                    <div class="sh-card-subtitle">Drop a file or browse from your computer.</div>
                </div>
            </div>
            <div class="sh-card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert" style="@(ViewContext.ModelState.IsValid ? "display:none;" : "")"></div>

                <label asp-for="File" class="form-label">CSV file</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-filetype-csv"></i></span>
                    <input asp-for="File" type="file" class="form-control" accept=".csv" />
                </div>
                <div class="form-text">Max file size 5MB. Only .csv files are accepted.</div>
                <span asp-validation-for="File" class="invalid-feedback d-block"></span>
            </div>
            <div class="sh-card-footer d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-cloud-upload"></i> Start upload
                </button>
            </div>
        </form>
    </div>
    <div class="col-lg-5">
        <div class="sh-card">
            <div class="sh-card-header">
                <div>
                    <h2 class="sh-card-title">Format guide</h2>
                    <div class="sh-card-subtitle">Columns in order</div>
                </div>
            </div>
            <div class="sh-card-body">
                <ol class="mb-3 ps-3" style="font-size:13px;">
                    <li>FirstName</li>
                    <li>LastName</li>
                    <li>Email</li>
                    <li>Salary</li>
                    <li>DepartmentName</li>
                    <li>Street</li>
                    <li>City</li>
                    <li>State</li>
                    <li>Country</li>
                </ol>
                <div class="sh-info-tile">
                    <div class="sh-info-tile-label">Example row</div>
                    <code class="small d-block mt-1" style="word-break:break-all;">John,Doe,john@example.com,5000,IT,123 Main St,Lagos,Lagos,Nigeria</code>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
