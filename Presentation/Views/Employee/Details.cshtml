@model Presentation.Models.EmployeeViewModel
@{
    ViewData["Title"] = $"{Model.FirstName} {Model.LastName}".Trim();
    var firstInitial = !string.IsNullOrWhiteSpace(Model.FirstName) ? Model.FirstName[0].ToString() : "";
    var lastInitial = !string.IsNullOrWhiteSpace(Model.LastName) ? Model.LastName[0].ToString() : "";
    var initials = $"{firstInitial}{lastInitial}";
    var departmentLabel = string.IsNullOrWhiteSpace(Model.DepartmentName) ? "Unassigned" : Model.DepartmentName;
}

<div class="sh-page-header">
    <div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Index" class="btn btn-link btn-sm px-0 mb-2" style="text-decoration:none;"><i class="bi bi-arrow-left"></i> Back to employees</a>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index" class="btn btn-link btn-sm px-0 mb-2" style="text-decoration:none;"><i class="bi bi-arrow-left"></i> Back to dashboard</a>
        }
        <h1 class="sh-page-title">@Model.FirstName @Model.LastName</h1>
        <p class="sh-page-subtitle">@departmentLabel &middot; Joined @Model.HireDate.ToString("MMMM dd, yyyy")</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="sh-page-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-controller="Offboarding" asp-action="Start" asp-route-employeeId="@Model.Id" class="btn btn-outline-secondary">
                <i class="bi bi-door-closed"></i> Offboard
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                <i class="bi bi-trash3"></i> Delete
            </a>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="sh-card mb-4">
            <div class="sh-card-body text-center">
                <div class="position-relative d-inline-block mb-3">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="Profile" class="sh-avatar sh-avatar-xl" />
                    }
                    else
                    {
                        <div class="sh-avatar sh-avatar-xl sh-avatar-primary">@initials</div>
                    }
                </div>
                <h2 class="mb-1" style="font-size:18px;">@Model.FirstName @Model.LastName</h2>
                <div class="sh-badge sh-badge-primary mb-3"><i class="bi bi-building"></i> @departmentLabel</div>
                @if (!string.IsNullOrEmpty(Model.ImageUrl) && User.IsInRole("Admin"))
                {
                    <form asp-action="DeleteImage" asp-route-employeeId="@Model.Id" method="post" class="mt-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Remove profile photo?')">
                            <i class="bi bi-trash3"></i> Remove photo
                        </button>
                    </form>
                }
            </div>
        </div>

        <div class="sh-card">
            <div class="sh-card-header">
                <h2 class="sh-card-title">Contact</h2>
            </div>
            <div class="sh-card-body">
                <div class="sh-detail-row">
                    <div class="sh-detail-label"><i class="bi bi-envelope"></i> Email</div>
                    <div class="sh-detail-value">@Model.Email</div>
                </div>
                <div class="sh-detail-row">
                    <div class="sh-detail-label"><i class="bi bi-telephone"></i> Phone</div>
                    <div class="sh-detail-value">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "—" : Model.PhoneNumber)</div>
                </div>
                <div class="sh-detail-row">
                    <div class="sh-detail-label"><i class="bi bi-person-badge"></i> Gender</div>
                    <div class="sh-detail-value">@(string.IsNullOrWhiteSpace(Model.Gender) ? "—" : Model.Gender)</div>
                </div>
                <div class="sh-detail-row">
                    <div class="sh-detail-label"><i class="bi bi-calendar-check"></i> Hire date</div>
                    <div class="sh-detail-value">@Model.HireDate.ToString("MMM dd, yyyy")</div>
                </div>
                <div class="sh-detail-row">
                    <div class="sh-detail-label"><i class="bi bi-cash-stack"></i> Salary</div>
                    <div class="sh-detail-value">@Model.Salary.ToString("C")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="sh-card mb-4">
            <div class="sh-card-header">
                <div>
                    <h2 class="sh-card-title">Address</h2>
                    <div class="sh-card-subtitle">Home address on file</div>
                </div>
                @if (Model.Address == null)
                {
                    <a asp-controller="Address" asp-action="Add" asp-route-employeeId="@Model.Id" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-geo-alt"></i> Add address
                    </a>
                }
                else
                {
                    <div class="d-flex gap-2">
                        <a asp-controller="Address" asp-action="Update" asp-route-employeeId="@Model.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                        <form asp-controller="Address" asp-action="Delete" asp-route-employeeId="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete address?')">Delete</button>
                        </form>
                    </div>
                }
            </div>
            <div class="sh-card-body">
                @if (Model.Address != null)
                {
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Street</div>
                                <div class="sh-info-tile-value">@(string.IsNullOrWhiteSpace(Model.Address.Street) ? "—" : Model.Address.Street)</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">City</div>
                                <div class="sh-info-tile-value">@(string.IsNullOrWhiteSpace(Model.Address.City) ? "—" : Model.Address.City)</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">State</div>
                                <div class="sh-info-tile-value">@(string.IsNullOrWhiteSpace(Model.Address.State) ? "—" : Model.Address.State)</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Country</div>
                                <div class="sh-info-tile-value">@(string.IsNullOrWhiteSpace(Model.Address.Country) ? "—" : Model.Address.Country)</div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="sh-empty">
                        <div class="sh-empty-icon"><i class="bi bi-geo-alt"></i></div>
                        <div class="sh-empty-title">No address on file</div>
                        <p class="sh-empty-text">Add an address to keep records complete.</p>
                    </div>
                }
            </div>
        </div>

        <div class="sh-card mb-4">
            <div class="sh-card-header">
                <div>
                    <h2 class="sh-card-title">Qualifications</h2>
                    <div class="sh-card-subtitle">Education and certifications</div>
                </div>
            </div>
            <div class="sh-card-body p-0">
                @if (Model.Qualifications.Count == 0)
                {
                    <div class="sh-card-body"><div class="text-muted small">No qualifications provided.</div></div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="sh-table mb-0">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Institution</th>
                                    <th>Year</th>
                                    <th>Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Qualifications)
                                {
                                    <tr>
                                        <td>@item.Title</td>
                                        <td>@item.Institution</td>
                                        <td>@item.Year</td>
                                        <td>@item.Grade</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="sh-card mb-4">
            <div class="sh-card-header">
                <div>
                    <h2 class="sh-card-title">Next of kin</h2>
                </div>
            </div>
            <div class="sh-card-body">
                @if (Model.NextOfKin == null)
                {
                    <div class="text-muted small">No next of kin details provided.</div>
                }
                else
                {
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Full name</div>
                                <div class="sh-info-tile-value">@Model.NextOfKin.FullName</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Relationship</div>
                                <div class="sh-info-tile-value">@Model.NextOfKin.Relationship</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Phone</div>
                                <div class="sh-info-tile-value">@Model.NextOfKin.PhoneNumber</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Address</div>
                                <div class="sh-info-tile-value">@Model.NextOfKin.Address</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="sh-card mb-4">
            <div class="sh-card-header">
                <div>
                    <h2 class="sh-card-title">HR information</h2>
                </div>
            </div>
            <div class="sh-card-body">
                @if (Model.HrInfo == null)
                {
                    <div class="text-muted small">No HR information provided.</div>
                }
                else
                {
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Date of birth</div>
                                <div class="sh-info-tile-value">@Model.HrInfo.DateOfBirth.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Marital status</div>
                                <div class="sh-info-tile-value">@Model.HrInfo.MaritalStatus</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">National ID</div>
                                <div class="sh-info-tile-value">@Model.HrInfo.NationalId</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Blood group</div>
                                <div class="sh-info-tile-value">@Model.HrInfo.BloodGroup</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="sh-info-tile">
                                <div class="sh-info-tile-label">Genotype</div>
                                <div class="sh-info-tile-value">@Model.HrInfo.Genotype</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="sh-card">
                <div class="sh-card-header">
                    <div>
                        <h2 class="sh-card-title">Documents</h2>
                        <div class="sh-card-subtitle">Employee files and credentials</div>
                    </div>
                </div>
                <div class="sh-card-body p-0">
                    @if (Model.Documents.Count == 0)
                    {
                        <div class="sh-card-body"><div class="text-muted small">No documents uploaded yet.</div></div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="sh-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>File</th>
                                        <th>Uploaded</th>
                                        <th>Expiry</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in Model.Documents)
                                    {
                                        <tr>
                                            <td>@doc.DocumentType</td>
                                            <td>@doc.FileName</td>
                                            <td>@doc.UploadedDate.ToString("MMM dd, yyyy")</td>
                                            <td>@(doc.ExpiryDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                            <td class="text-end">
                                                <a href="@doc.FileUrl" class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener">
                                                    <i class="bi bi-box-arrow-up-right"></i> View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<form id="antiforgeryForm">
    @Html.AntiForgeryToken()
</form>
